void WRITE_PIN(const PIN_t* pin, bool val){
	if(val == 1) *(pin->reg)|= pin->bit;
	else *(pin->reg)&= ~(pin->bit);
}

bool READ_PIN(const PIN_t*pin){
	return (*(pin->reg)&pin->bit) ? true : false ;
}

