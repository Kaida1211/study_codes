#include "iodefine.h"
#include "stdint.h"
#include "stdbool.h"

#define init_PIN(port, reg, bit) {				\
	0, 											\
	(volatile uint8_t*)&PORT##port.reg.BYTE,  \
	(uint8_t)(1 << (bit))						\
}

#define init_TCN(tgr) {\
	(volatile uint16_t*)tgr	\
	0,						\
	0						\
}

typedef struct{
	volatile uint8_t* reg;
	uint8_t bit;
}PIN_t;

typedef struct{
	volatile uint16_t *tgr;
}TCNT_t;

typedef struct{
	TCNT_t IN;
	PIN_t SD;
	PIN_t HL;
}MOTER_PIN;

typedef struct{
	MOTER_PIN U;
	MOTER_PIN V;
	MOTER_PIN W;
}MOTER_t;

typedef enum{
	L,
	R
}MOTER_SIDE;

